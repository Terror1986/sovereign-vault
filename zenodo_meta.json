{"created": "2024-06-17T18:01:57.427540+00:00", "modified": "2024-06-17T18:01:57.874909+00:00", "id": 11985455, "conceptrecid": "11985454", "doi": "10.5281/zenodo.11985455", "conceptdoi": "10.5281/zenodo.11985454", "doi_url": "https://doi.org/10.5281/zenodo.11985455", "metadata": {"title": "Nominal FAST5/FASTQ Evaluation Data Set", "doi": "10.5281/zenodo.11985455", "publication_date": "2024-06-17", "description": "<p>FAST5/FASTQ data used for accuracy characterization of decoding techniques applied to the HEDGEs DNA-information storage code. FASTQ data is used to evaluate the hard-decoding algorithm as explained by Press et al. in (<a href=\"https://doi.org/10.1073/pnas.2004821117\">https://doi.org/10.1073/pnas.2004821117</a>). FAST5 data is used in evaluation for both our novel Alignment Matrix soft decoder (<a href=\"https://doi.org/10.5281/zenodo.11454877\">https://doi.org/10.5281/zenodo.11454877</a>), and the soft decoder developed by Chandak et al. in the publication (<a href=\"https://doi-org.prox.lib.ncsu.edu/10.1109/ICASSP40776.2020.9053441\">10.1109/ICASSP40776.2020.9053441</a>). Our code repository at <a href=\"https://doi.org/10.5281/zenodo.11454877\">https://doi.org/10.5281/zenodo.11454877</a> includes a GPU accelerated adaptation of Chandak et al.&rsquo;s algorithm in order to scale analysis on the submitted FAST5 data, and this is the version of code used to evaluate the algorithm&rsquo;s accuracy and runtime overhead.</p>\n<p>&nbsp;</p>\n<p>Within the archive there are several sub-archives. Explanations for each sub-archive can be found for the corresponding archive name within the README.md file.</p>\n<p>&nbsp;</p>", "access_right": "open", "creators": [{"name": "Volkel, Kevin", "affiliation": "North Carolina State University"}], "contributors": [{"name": "Volkel, Kevin", "affiliation": "North Carolina State University", "type": "ContactPerson", "orcid": "0000-0002-5200-5909"}, {"name": "Hook, Paul", "affiliation": "Johns Hopkins University", "type": "DataCollector"}, {"name": "Timp, Winston", "affiliation": "Johns Hopkins University", "type": "Supervisor"}, {"name": "Keung, Albert", "affiliation": "North Carolina State University", "type": "Supervisor"}, {"name": "Tuck, James", "affiliation": "North Carolina State University", "type": "Supervisor"}], "resource_type": {"title": "Dataset", "type": "dataset"}, "license": {"id": "cc-by-4.0"}, "relations": {"version": [{"index": 0, "is_last": true, "parent": {"pid_type": "recid", "pid_value": "11985454"}}]}}, "title": "Nominal FAST5/FASTQ Evaluation Data Set", "links": {"self": "https://zenodo.org/api/records/11985455", "self_html": "https://zenodo.org/records/11985455", "preview_html": "https://zenodo.org/records/11985455?preview=1", "doi": "https://doi.org/10.5281/zenodo.11985455", "self_doi": "https://doi.org/10.5281/zenodo.11985455", "self_doi_html": "https://zenodo.org/doi/10.5281/zenodo.11985455", "reserve_doi": "https://zenodo.org/api/records/11985455/draft/pids/doi", "parent": "https://zenodo.org/api/records/11985454", "parent_html": "https://zenodo.org/records/11985454", "parent_doi": "https://doi.org/10.5281/zenodo.11985454", "parent_doi_html": "https://zenodo.org/doi/10.5281/zenodo.11985454", "self_iiif_manifest": "https://zenodo.org/api/iiif/record:11985455/manifest", "self_iiif_sequence": "https://zenodo.org/api/iiif/record:11985455/sequence/default", "files": "https://zenodo.org/api/records/11985455/files", "media_files": "https://zenodo.org/api/records/11985455/media-files", "archive": "https://zenodo.org/api/records/11985455/files-archive", "archive_media": "https://zenodo.org/api/records/11985455/media-files-archive", "latest": "https://zenodo.org/api/records/11985455/versions/latest", "latest_html": "https://zenodo.org/records/11985455/latest", "versions": "https://zenodo.org/api/records/11985455/versions", "draft": "https://zenodo.org/api/records/11985455/draft", "access_links": "https://zenodo.org/api/records/11985455/access/links", "access_gran